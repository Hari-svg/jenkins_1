 &lt;td valign=&quot;top&quot; class=&quot;PersonalData&quot;&gt; &lt;div align=&quot;right&quot;&gt;&lt;strong&gt;Balance 
&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/strong&gt;&lt;/div&gt;&lt;/td&gt;
 &lt;td valign=&quot;top&quot; class=&quot;PersonalData&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;96381/-&lt;/td&gt;
