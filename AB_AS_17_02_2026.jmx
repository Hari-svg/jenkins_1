                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="script">def AccountNo   = vars.get(&quot;C_AccNo&quot;)
def AccountType = vars.get(&quot;C_AccType&quot;)
def Name        = vars.get(&quot;C_AccName&quot;)
def City        = vars.get(&quot;C_City&quot;) 
def PhoneNum    = vars.get(&quot;C_PhNo&quot;) 
def Email       = vars.get(&quot;C_Email&quot;) 
def Accbalance  = vars.get(&quot;C_Balance&quot;) 


def file = new File(&quot;E:/Arabian__Banking/Jmeter_Projects/Jmter_write_files/AccountDetails.csv&quot;)

if (!file.exists()) {
    file.write(&quot;AccountNo,AccountType,Name,City,PhoneNum,Email,Accbalance\n&quot;, &quot;UTF-8&quot;)
}

file.append(&quot;\&quot;${AccountNo}\&quot;,\&quot;${AccountType}\&quot;,\&quot;${Name}\&quot;,\&quot;${City}\&quot;,\&quot;${PhoneNum}\&quot;,\&quot;${Email}\&quot;,\&quot;${Accbalance}\&quot;\n&quot;,&quot;UTF-8&quot;);

// Write response to file (overwrite)
//file.write(response, &quot;UTF-8&quot;)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
                </JSR223PostProcessor>
                <hashTree/>
              </hashTree>
            </hashTree>
